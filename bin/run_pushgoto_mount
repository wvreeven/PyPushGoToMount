#!/usr/bin/env python

import asyncio
import logging
import pathlib
import sys

from pypushgotomount import run_pushgoto_mount

log_file = pathlib.Path.home() / "pypushgotomount_debug.log"

logging.basicConfig(
    format="%(asctime)s:%(levelname)s:%(name)s:%(message)s",
    level=logging.INFO,
    handlers=[logging.FileHandler(log_file), logging.StreamHandler(sys.stdout)],
)

asyncio.run(run_pushgoto_mount())
